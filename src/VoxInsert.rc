#include <winres.h>

#include "resource.h"

IDI_APP_ICON ICON "..\\assets\\VoxInsertIcon.ico"
IDI_TRAY_ICON ICON "..\\assets\\VoxInsertTray.ico"

IDD_SETTINGS_DIALOG DIALOGEX 0, 0, 258, 278
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "VoxInsert Settings"
FONT 9, "Segoe UI"
BEGIN
	CONTROL         "",IDC_SETTINGS_TABS,"SysTabControl32",WS_TABSTOP,7,7,244,243
	LTEXT           "Transcription provider:",IDC_SETTINGS_TRANSCRIPTION_PROVIDER_LABEL,18,30,88,8
	COMBOBOX        IDC_SETTINGS_TRANSCRIPTION_PROVIDER,112,27,118,70,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
	LTEXT           "Language hint:",IDC_SETTINGS_LANGUAGE_HINT_LABEL,18,49,88,8
	EDITTEXT        IDC_SETTINGS_LANGUAGE_HINT,112,46,118,14,ES_AUTOHSCROLL | WS_TABSTOP
	AUTOCHECKBOX    "Use legacy file transcription (turn off live streaming)",IDC_SETTINGS_STREAMING_ENABLED,18,69,212,10
	AUTOCHECKBOX    "Start VoxInsert with Windows",IDC_SETTINGS_START_WITH_WINDOWS,18,83,160,10
	AUTOCHECKBOX    "Show status pill",IDC_SETTINGS_SHOW_STATUS_PILL,18,101,160,10
	AUTOCHECKBOX    "Show live transcript preview in status pill",IDC_SETTINGS_SHOW_TRANSCRIPT_PREVIEW,18,115,212,10
	AUTOCHECKBOX    "Use headset/media Play/Pause to toggle recording",IDC_SETTINGS_USE_MEDIA_PLAY_PAUSE_TOGGLE,18,131,212,10
	LTEXT           "Toggle recording hotkey:",IDC_SETTINGS_TOGGLE_HOTKEY_LABEL,18,150,88,8
	CONTROL         "",IDC_SETTINGS_TOGGLE_HOTKEY,"msctls_hotkey32",WS_TABSTOP,112,147,70,14
	LTEXT           "Cancel hotkey:",IDC_SETTINGS_CANCEL_HOTKEY_LABEL,18,170,88,8
	CONTROL         "",IDC_SETTINGS_CANCEL_HOTKEY,"msctls_hotkey32",WS_TABSTOP,112,167,70,14
	LTEXT           "Status pill placement:",IDC_SETTINGS_STATUS_PILL_POSITION_LABEL,18,190,88,8
	COMBOBOX        IDC_SETTINGS_STATUS_PILL_POSITION,112,187,118,90,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
	LTEXT           "Click a hotkey field, then press the shortcut you want. VoxInsert pauses global hotkeys while this dialog is open.",IDC_SETTINGS_HOTKEY_HINT,18,207,214,16
	LTEXT           "Settings are saved to %APPDATA%\VoxInsert\config.json and applied when you press Save.",IDC_SETTINGS_SAVE_HINT,18,225,214,16
	LTEXT           "Model (file):",IDC_SETTINGS_OPENAI_MODEL_LABEL,18,30,88,8
	EDITTEXT        IDC_SETTINGS_OPENAI_MODEL,112,27,118,14,ES_AUTOHSCROLL | WS_TABSTOP
	LTEXT           "Streaming model:",IDC_SETTINGS_OPENAI_STREAMING_MODEL_LABEL,18,49,88,8
	EDITTEXT        IDC_SETTINGS_OPENAI_STREAMING_MODEL,112,46,118,14,ES_AUTOHSCROLL | WS_TABSTOP
	LTEXT           "Credential target:",IDC_SETTINGS_OPENAI_TARGET_LABEL,18,68,88,8
	EDITTEXT        IDC_SETTINGS_OPENAI_TARGET,112,65,118,14,ES_AUTOHSCROLL | WS_TABSTOP
	LTEXT           "API key:",IDC_SETTINGS_OPENAI_API_KEY_LABEL,18,87,88,8
	EDITTEXT        IDC_SETTINGS_OPENAI_API_KEY,112,84,118,14,ES_AUTOHSCROLL | ES_PASSWORD | WS_TABSTOP
	AUTOCHECKBOX    "Remove stored key",IDC_SETTINGS_OPENAI_REMOVE_KEY,112,103,118,10
	LTEXT           "",IDC_SETTINGS_OPENAI_API_KEY_HINT,18,119,214,16
	LTEXT           "Prompt:",IDC_SETTINGS_OPENAI_PROMPT_LABEL,18,139,88,8
	EDITTEXT        IDC_SETTINGS_OPENAI_PROMPT,18,150,212,52,ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL | WS_TABSTOP
	LTEXT           "Model (file):",IDC_SETTINGS_MISTRAL_MODEL_LABEL,18,30,88,8
	EDITTEXT        IDC_SETTINGS_MISTRAL_MODEL,112,27,118,14,ES_AUTOHSCROLL | WS_TABSTOP
	LTEXT           "Streaming model:",IDC_SETTINGS_MISTRAL_STREAMING_MODEL_LABEL,18,49,88,8
	EDITTEXT        IDC_SETTINGS_MISTRAL_STREAMING_MODEL,112,46,118,14,ES_AUTOHSCROLL | WS_TABSTOP
	LTEXT           "Credential target:",IDC_SETTINGS_MISTRAL_TARGET_LABEL,18,68,88,8
	EDITTEXT        IDC_SETTINGS_MISTRAL_TARGET,112,65,118,14,ES_AUTOHSCROLL | WS_TABSTOP
	LTEXT           "API key:",IDC_SETTINGS_MISTRAL_API_KEY_LABEL,18,87,88,8
	EDITTEXT        IDC_SETTINGS_MISTRAL_API_KEY,112,84,118,14,ES_AUTOHSCROLL | ES_PASSWORD | WS_TABSTOP
	AUTOCHECKBOX    "Remove stored key",IDC_SETTINGS_MISTRAL_REMOVE_KEY,112,103,118,10
	LTEXT           "",IDC_SETTINGS_MISTRAL_API_KEY_HINT,18,119,214,18
	LTEXT           "Context bias:",IDC_SETTINGS_MISTRAL_CONTEXT_BIAS_LABEL,18,141,88,8
	EDITTEXT        IDC_SETTINGS_MISTRAL_CONTEXT_BIAS,18,152,212,52,ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL | WS_TABSTOP
	AUTOCHECKBOX    "Archive completed dictations",IDC_SETTINGS_ARCHIVE_ENABLED,18,30,180,10
	AUTOCHECKBOX    "Save transcript text",IDC_SETTINGS_ARCHIVE_TRANSCRIPT,18,52,180,10
	AUTOCHECKBOX    "Save compressed Opus audio",IDC_SETTINGS_ARCHIVE_AUDIO,18,70,180,10
	LTEXT           "Archive folder:",IDC_SETTINGS_ARCHIVE_FOLDER_LABEL,18,94,88,8
	EDITTEXT        IDC_SETTINGS_ARCHIVE_FOLDER,18,106,172,14,ES_AUTOHSCROLL | WS_TABSTOP
	PUSHBUTTON      "Browse",IDC_SETTINGS_ARCHIVE_BROWSE,196,105,34,14
	LTEXT           "Archived clips are written as .txt, .json, and .opus files under dated subfolders.",IDC_SETTINGS_ARCHIVE_HINT,18,132,214,24
	PUSHBUTTON      "Reset Defaults",IDC_SETTINGS_RESET_DEFAULTS,18,255,80,14
	DEFPUSHBUTTON   "Save",IDOK,140,255,50,14
	PUSHBUTTON      "Cancel",IDCANCEL,196,255,50,14
END

1 24 "VoxInsert.manifest"
