#include <winres.h>

#include "resource.h"

IDI_APP_ICON ICON "..\\assets\\VoxInsertIcon.ico"
IDI_TRAY_ICON ICON "..\\assets\\VoxInsertTray.ico"

IDD_SETTINGS_DIALOG DIALOGEX 0, 0, 258, 258
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "VoxInsert Settings"
FONT 9, "Segoe UI"
BEGIN
	CONTROL         "",IDC_SETTINGS_TABS,"SysTabControl32",WS_TABSTOP,7,7,244,223
	LTEXT           "Transcription provider:",IDC_SETTINGS_TRANSCRIPTION_PROVIDER_LABEL,18,30,88,8
	COMBOBOX        IDC_SETTINGS_TRANSCRIPTION_PROVIDER,112,27,118,70,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
	LTEXT           "Language hint:",IDC_SETTINGS_LANGUAGE_HINT_LABEL,18,49,88,8
	EDITTEXT        IDC_SETTINGS_LANGUAGE_HINT,112,46,118,14,ES_AUTOHSCROLL | WS_TABSTOP
	AUTOCHECKBOX    "Start VoxInsert with Windows",IDC_SETTINGS_START_WITH_WINDOWS,18,69,160,10
	AUTOCHECKBOX    "Show status pill",IDC_SETTINGS_SHOW_STATUS_PILL,18,87,160,10
	LTEXT           "Toggle recording hotkey:",IDC_SETTINGS_TOGGLE_HOTKEY_LABEL,18,108,88,8
	CONTROL         "",IDC_SETTINGS_TOGGLE_HOTKEY,"msctls_hotkey32",WS_TABSTOP,112,105,70,14
	LTEXT           "Cancel hotkey:",IDC_SETTINGS_CANCEL_HOTKEY_LABEL,18,128,88,8
	CONTROL         "",IDC_SETTINGS_CANCEL_HOTKEY,"msctls_hotkey32",WS_TABSTOP,112,125,70,14
	LTEXT           "Status pill placement:",IDC_SETTINGS_STATUS_PILL_POSITION_LABEL,18,148,88,8
	COMBOBOX        IDC_SETTINGS_STATUS_PILL_POSITION,112,145,118,90,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
	LTEXT           "Click a hotkey field, then press the shortcut you want. VoxInsert pauses global hotkeys while this dialog is open.",IDC_SETTINGS_HOTKEY_HINT,18,168,214,20
	LTEXT           "Settings are saved to %APPDATA%\VoxInsert\config.json and applied when you press Save.",IDC_SETTINGS_SAVE_HINT,18,192,214,20
	LTEXT           "Model:",IDC_SETTINGS_OPENAI_MODEL_LABEL,18,30,88,8
	EDITTEXT        IDC_SETTINGS_OPENAI_MODEL,112,27,118,14,ES_AUTOHSCROLL | WS_TABSTOP
	LTEXT           "Credential target:",IDC_SETTINGS_OPENAI_TARGET_LABEL,18,49,88,8
	EDITTEXT        IDC_SETTINGS_OPENAI_TARGET,112,46,118,14,ES_AUTOHSCROLL | WS_TABSTOP
	LTEXT           "API key:",IDC_SETTINGS_OPENAI_API_KEY_LABEL,18,68,88,8
	EDITTEXT        IDC_SETTINGS_OPENAI_API_KEY,112,65,118,14,ES_AUTOHSCROLL | ES_PASSWORD | WS_TABSTOP
	AUTOCHECKBOX    "Remove stored key",IDC_SETTINGS_OPENAI_REMOVE_KEY,112,84,118,10
	LTEXT           "",IDC_SETTINGS_OPENAI_API_KEY_HINT,18,100,214,18
	LTEXT           "Prompt:",IDC_SETTINGS_OPENAI_PROMPT_LABEL,18,122,88,8
	EDITTEXT        IDC_SETTINGS_OPENAI_PROMPT,18,133,212,56,ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL | WS_TABSTOP
	LTEXT           "Model:",IDC_SETTINGS_MISTRAL_MODEL_LABEL,18,30,88,8
	EDITTEXT        IDC_SETTINGS_MISTRAL_MODEL,112,27,118,14,ES_AUTOHSCROLL | WS_TABSTOP
	LTEXT           "Credential target:",IDC_SETTINGS_MISTRAL_TARGET_LABEL,18,49,88,8
	EDITTEXT        IDC_SETTINGS_MISTRAL_TARGET,112,46,118,14,ES_AUTOHSCROLL | WS_TABSTOP
	LTEXT           "API key:",IDC_SETTINGS_MISTRAL_API_KEY_LABEL,18,68,88,8
	EDITTEXT        IDC_SETTINGS_MISTRAL_API_KEY,112,65,118,14,ES_AUTOHSCROLL | ES_PASSWORD | WS_TABSTOP
	AUTOCHECKBOX    "Remove stored key",IDC_SETTINGS_MISTRAL_REMOVE_KEY,112,84,118,10
	LTEXT           "",IDC_SETTINGS_MISTRAL_API_KEY_HINT,18,100,214,18
	LTEXT           "Context bias:",IDC_SETTINGS_MISTRAL_CONTEXT_BIAS_LABEL,18,122,88,8
	EDITTEXT        IDC_SETTINGS_MISTRAL_CONTEXT_BIAS,18,133,212,56,ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL | WS_TABSTOP
	AUTOCHECKBOX    "Archive completed dictations",IDC_SETTINGS_ARCHIVE_ENABLED,18,30,180,10
	AUTOCHECKBOX    "Save transcript text",IDC_SETTINGS_ARCHIVE_TRANSCRIPT,18,52,180,10
	AUTOCHECKBOX    "Save compressed Opus audio",IDC_SETTINGS_ARCHIVE_AUDIO,18,70,180,10
	LTEXT           "Archive folder:",IDC_SETTINGS_ARCHIVE_FOLDER_LABEL,18,94,88,8
	EDITTEXT        IDC_SETTINGS_ARCHIVE_FOLDER,18,106,172,14,ES_AUTOHSCROLL | WS_TABSTOP
	PUSHBUTTON      "Browse",IDC_SETTINGS_ARCHIVE_BROWSE,196,105,34,14
	LTEXT           "Archived clips are written as .txt, .json, and .opus files under dated subfolders.",IDC_SETTINGS_ARCHIVE_HINT,18,132,214,24
	PUSHBUTTON      "Reset Defaults",IDC_SETTINGS_RESET_DEFAULTS,18,235,80,14
	DEFPUSHBUTTON   "Save",IDOK,140,235,50,14
	PUSHBUTTON      "Cancel",IDCANCEL,196,235,50,14
END

1 24 "VoiceAgentTyper.manifest"