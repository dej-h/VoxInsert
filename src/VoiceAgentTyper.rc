#include <winres.h>

#include "resource.h"

IDI_APP_ICON ICON "..\\assets\\VoxInsertIcon.ico"
IDI_TRAY_ICON ICON "..\\assets\\VoxInsertTray.ico"

IDD_OPENAI_KEY_DIALOG DIALOGEX 0, 0, 250, 86
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Configure OpenAI Key"
FONT 9, "Segoe UI"
BEGIN
	LTEXT           "VoxInsert stores your OpenAI API key in Windows Credential Manager for the current Windows account.",-1,7,7,236,18
	LTEXT           "Credential target:",-1,7,31,58,8
	LTEXT           "",IDC_OPENAI_TARGET_VALUE,69,31,174,8
	LTEXT           "API key:",-1,7,47,40,8
	EDITTEXT        IDC_OPENAI_API_KEY_EDIT,69,44,174,14,ES_AUTOHSCROLL | ES_PASSWORD
	DEFPUSHBUTTON   "Save",IDOK,132,65,50,14
	PUSHBUTTON      "Cancel",IDCANCEL,188,65,50,14
END

IDD_SETTINGS_DIALOG DIALOGEX 0, 0, 250, 176
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "VoxInsert Settings"
FONT 9, "Segoe UI"
BEGIN
	AUTOCHECKBOX    "Start VoxInsert with Windows",IDC_SETTINGS_START_WITH_WINDOWS,7,10,180,10
	AUTOCHECKBOX    "Show status pill",IDC_SETTINGS_SHOW_STATUS_PILL,7,28,180,10
	LTEXT           "Toggle recording hotkey:",-1,7,48,80,8
	CONTROL         "",IDC_SETTINGS_TOGGLE_HOTKEY,"msctls_hotkey32",WS_TABSTOP,98,45,70,14
	LTEXT           "Cancel hotkey:",-1,7,68,80,8
	CONTROL         "",IDC_SETTINGS_CANCEL_HOTKEY,"msctls_hotkey32",WS_TABSTOP,98,65,70,14
	LTEXT           "Status pill placement:",IDC_SETTINGS_STATUS_PILL_POSITION_LABEL,7,88,86,8
	COMBOBOX        IDC_SETTINGS_STATUS_PILL_POSITION,98,85,118,90,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
	LTEXT           "Click a hotkey field, then press the shortcut you want. VoxInsert pauses global hotkeys while this dialog is open.",IDC_SETTINGS_HOTKEY_HINT,7,108,236,20
	LTEXT           "Settings are saved to %APPDATA%\\VoxInsert\\config.json and applied when you press Save.",-1,7,132,236,20
	DEFPUSHBUTTON   "Save",IDOK,132,155,50,14
	PUSHBUTTON      "Cancel",IDCANCEL,188,155,50,14
END

1 24 "VoiceAgentTyper.manifest"